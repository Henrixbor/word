{
  "expo": {
    "name": "Word!",
    "slug": "word",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "wordgame",
    "icon": "./assets/branding/app-icon.png",
    "splash": {
      "image": "./assets/branding/splash-image.png",
      "resizeMode": "cover",
      "backgroundColor": "#183A4A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordgame.app",
      "infoPlist": {
        "NSGKFriendListUsageDescription": "Wordgame uses your Game Center friends to help you find and add people you already play with."
      }
    },
    "android": {
      "package": "com.wordgame.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon.png",
        "backgroundColor": "#183A4A"
      },
      "permissions": [
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withGameCenter"
    ],
    "web": {
      "favicon": "./assets/branding/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    },
    "owner": "Henrixbor"
  }
}
