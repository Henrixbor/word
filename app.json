{
  "expo": {
    "name": "Wordgame",
    "slug": "wordgame",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "wordgame",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordgame.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan QR codes for tournament entry.",
        "NSMicrophoneUsageDescription": "This app does not use the microphone.",
        "GADApplicationIdentifier": "ca-app-pub-XXXXX~XXXXX",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork"
          }
        ]
      },
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-XXXXX~XXXXX"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.wordgame.app",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-XXXXX~XXXXX"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1"
        }
      ],
      [
        "expo-ads-admob",
        {
          "androidAppId": "ca-app-pub-XXXXX~XXXXX",
          "iosAppId": "ca-app-pub-XXXXX~XXXXX"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Wordgame to use your camera to scan tournament QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "owner": "wordgame"
  }
}
